# Copy to .env.local and fill with your Supabase project values
# (Supabase dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Set to "true" only after you enable the Google provider in Supabase.
# When unset, the "Continue with Google" button is hidden.
NEXT_PUBLIC_ENABLE_GOOGLE=false

# Server-only (never exposed to the browser). Required for account deletion to
# also remove the Supabase auth record. Without it, "Delete account" still wipes
# the user's data but leaves the auth row. Supabase dashboard → Project Settings
# → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-SECRET

# --- Email (daily cron) ---------------------------------------------------
# Which email provider to use: "console" (default, logs only) or "brevo".
# Switch senders later by changing just this value.
EMAIL_PROVIDER=console

# Brevo (only needed when EMAIL_PROVIDER=brevo). Dashboard → SMTP & API → API Keys.
BREVO_API_KEY=YOUR-BREVO-API-KEY
# Sender address (must be a verified sender/domain in Brevo).
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_FROM_NAME=Stackt

# Shared secret Vercel sends as `Authorization: Bearer <CRON_SECRET>`.
# Set it in Vercel so the cron endpoint can't be triggered publicly.
CRON_SECRET=SOME-LONG-RANDOM-STRING
