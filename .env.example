# Copy to .env.local and fill with your Supabase project values
# (Supabase dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Set to "true" only after you enable the Google provider in Supabase.
# When unset, the "Continue with Google" button is hidden.
NEXT_PUBLIC_ENABLE_GOOGLE=false

# Server-only (never exposed to the browser). Required for account deletion to
# also remove the Supabase auth record. Without it, "Delete account" still wipes
# the user's data but leaves the auth row. Supabase dashboard → Project Settings
# → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-SECRET
